{
  "probeDefaults": {
    "startupProbe": {
      "initialDelaySeconds": 0,
      "periodSeconds": 10,
      "timeoutSeconds": 1,
      "successThreshold": 1,
      "failureThreshold": 30
    },
    "actions": {
      "exec": {
        "command": []
      },
      "httpGet": {
        "host": "",
        "port": null,
        "path": "/",
        "scheme": "HTTP",
        "httpHeaders": []
      },
      "tcpSocket": {
        "host": "",
        "port": null
      },
      "grpc": {
        "port": null,
        "service": null
      }
    },
    "notes": {
      "terminationGracePeriodSeconds": null,
      "remarks": "部分字段如port无默认值且通常为必填;terminationGracePeriodSeconds 不是 probe 字段，而是 Pod 级别的终止宽限期。"
    }
  }
}
